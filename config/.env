# Copy this file and rename to .env in the project root

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=smart_inventory

# Server Configuration
PORT=3000
HOST=localhost
NODE_ENV=development

ADMIN_USERNAME=admin
ADMIN_FULLNAME=Admin User
ADMIN_PASSWORD=admin123

# CORS Configuration
CORS_ORIGIN=http://localhost:4200

# JWT (required for /api/auth/login — use a long random string in production)
JWT_SECRET=dev-change-me-use-openssl-rand-hex-32-in-production

